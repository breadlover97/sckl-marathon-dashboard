# Google Sheets API setup for planned training sync.
# Copy these into your shell, GitHub Actions secrets/vars, or local .env loader.

GOOGLE_SHEET_ID=1sx46WZYNJNBBTtPoG2E3obdVrzUIhfa7-m84DWOvVDo

# A1 range to read/write. Keep the default if your first tab has the expected columns.
# If you rename the tab, quote the whole value in your shell:
# export GOOGLE_SHEET_RANGE="'Training Plan'!A:AQ"
GOOGLE_SHEET_RANGE=A:AQ

# Use one of these credential approaches.
# Local file path:
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-service-account.json

# Or one-line JSON, useful for GitHub Actions secrets:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

GOOGLE_SHEET_OUTPUT=data/training-plan.json

# Optional Google Calendar sync for planned training. Share the target calendar
# with the service account, then set GOOGLE_CALENDAR_ID to that calendar ID or
# email. The sync script previews by default and only writes with --apply.
GOOGLE_CALENDAR_ID=your_calendar_id_or_email
TRAINING_CALENDAR_START_DATE=2026-05-29
TRAINING_CALENDAR_END_DATE=2026-10-04
TRAINING_CALENDAR_TIMEZONE=Asia/Singapore
TRAINING_CALENDAR_COLOR_ID=11

# Supplement checkbox history for the main dashboard.
GOOGLE_SUPPLEMENTS_RANGE=Supplements!A:F
GOOGLE_SUPPLEMENTS_OUTPUT=data/supplements.json

# Nutrition tab sync. The site displays this read-only and does not call
# nutrition estimation APIs directly from Cloudflare Pages.
GOOGLE_NUTRITION_RANGE=Nutrition!A:T
GOOGLE_NUTRITION_OUTPUT=data/nutrition.json

# Optional private AI processing step. This runs in GitHub Actions or locally,
# writes estimates back to Google Sheets, then the normal sync publishes JSON.
GOOGLE_NUTRITION_AI_RANGE=Nutrition!A:T
OPENAI_API_KEY=
OPENAI_NUTRITION_MODEL=gpt-4.1-mini
NUTRITION_AI_LIMIT=20

# Strava API setup for actual run sync.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
STRAVA_ACTIVITIES_OUTPUT=data/strava-activities.json
STRAVA_VERIFY_TOKEN=
STRAVA_SYNC_SECRET=
STRAVA_WORKER_URL=https://sckl-strava-sync.ngimtaizhi.workers.dev
STRAVA_WEBHOOK_CALLBACK_URL=https://sckl-strava-sync.ngimtaizhi.workers.dev/api/strava/webhook
